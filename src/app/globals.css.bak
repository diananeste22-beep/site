@import "tailwindcss";

:root {
  --background: #f1f8ff;
  --foreground: #272727;
  --accent: #2d63fc;
  /* Unified block radius shared by frame, cards and popups */
  --radius-block: 26px;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-manrope), Arial, Helvetica, sans-serif;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  scroll-padding-top: 84px;
  background: var(--background);
}

body {
  min-width: 320px;
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-manrope), Arial, Helvetica, sans-serif;
  font-feature-settings: "ss01" on;
}

::selection {
  background: var(--accent);
  color: #f1f8ff;
}

h1,
h2,
h3,
.toolbar-link,
.accent-swipe,
.niche-rotator {
  font-family: var(--font-manrope), Arial, Helvetica, sans-serif;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
}

img {
  max-width: 100%;
}

.grid-flick-overlay {
  mix-blend-mode: multiply;
}

.hero-grid {
  opacity: 0.68;
  mix-blend-mode: multiply;
}

.hero-niche-mask {
  position: relative;
  display: inline-block;
  min-width: 5.65em;
  height: 0.98em;
  overflow: hidden;
  vertical-align: baseline;
  clip-path: inset(-0.18em 0 -0.16em 0);
}

.hero-niche-word {
  position: absolute;
  left: 0;
  top: 0;
  display: block;
  line-height: 0.98;
  white-space: nowrap;
  will-change: opacity, transform, filter;
}



.section-band {
  position: relative;
}

.services-surface,
.workflow-surface,
.portfolio-surface {
  position: relative;
  overflow: hidden;
}

.services-surface::before,
.workflow-surface::before,
.portfolio-surface::before {
  position: absolute;
  inset: 0;
  content: "";
  pointer-events: none;
  border-radius: inherit;
  background:
    linear-gradient(135deg, rgba(45, 99, 252, 0.1), transparent 34%),
    linear-gradient(0deg, rgba(241, 248, 255, 0.72), rgba(241, 248, 255, 0));
  opacity: 0.78;
}

.services-surface > *,
.workflow-surface > *,
.portfolio-surface > * {
  position: relative;
  z-index: 1;
}

.service-card > .relative,
.service-card .aspect-\[16\/10\] {
  position: relative;
}

.service-card .aspect-\[16\/10\] {
  overflow: hidden;
}

.service-chip {
  min-height: 48px;
  transition: border-color 220ms ease, background-color 220ms ease, color 220ms ease, transform 220ms ease;
}

.service-card:hover .service-chip {
  border-color: rgba(45, 99, 252, 0.22);
  background: rgba(45, 99, 252, 0.08);
}

.service-toolkit {
  isolation: isolate;
}

.service-toolkit::before {
  position: absolute;
  inset: 0;
  z-index: -1;
  content: "";
  background:
    linear-gradient(90deg, rgba(241, 248, 255, 0.1) 1px, transparent 1px),
    linear-gradient(0deg, rgba(241, 248, 255, 0.1) 1px, transparent 1px);
  background-size: 28px 28px;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.85), transparent 78%);
}

.workflow-poster {
  isolation: isolate;
}

.workflow-poster::before {
  position: absolute;
  inset: auto 1.5rem 1.5rem 1.5rem;
  z-index: -1;
  height: 42%;
  content: "";
  border-radius: 8px;
  background:
    repeating-linear-gradient(135deg, rgba(45, 99, 252, 0.22) 0 2px, transparent 2px 14px),
    linear-gradient(135deg, rgba(45, 99, 252, 0.16), rgba(39, 39, 39, 0.08));
}

.workflow-orbit span {
  transition: transform 260ms ease, background-color 260ms ease;
}

.workflow-poster:hover .workflow-orbit span:nth-child(1) {
  transform: translateY(-4px);
}

.workflow-poster:hover .workflow-orbit span:nth-child(2) {
  transform: translateY(4px);
}

.workflow-poster:hover .workflow-orbit span:nth-child(3) {
  transform: translateY(-4px);
  background: #2d63fc;
}

.workflow-section .workflow-step-card:hover h3 {
  color: inherit;
}

.workflow-section .workflow-step-card::after {
  background: #f1f8ff;
}

.workflow-section .workflow-step-card:last-child::after {
  background: #272727;
}

.service-tile,
.workflow-step-card,
.portfolio-card,
.contact-link {
  position: relative;
  will-change: transform, opacity;
}

.reveal-ready #services .service-tile,
.reveal-ready #workflow .workflow-step-card,
.reveal-ready #portfolio .portfolio-card,
.reveal-ready footer .contact-link {
  opacity: 0;
  transform: translateY(18px);
  transition:
    opacity 620ms ease,
    transform 720ms cubic-bezier(0.2, 0.82, 0.16, 1);
}

.reveal-ready #services.is-visible .service-tile,
.reveal-ready #workflow.is-visible .workflow-step-card,
.reveal-ready #portfolio.is-visible .portfolio-card,
.reveal-ready footer.is-visible .contact-link {
  opacity: 1;
  transform: translateY(0);
}

.reveal-ready #services.is-visible .service-tile:nth-child(2),
.reveal-ready #workflow.is-visible .workflow-step-card:nth-child(2),
.reveal-ready #portfolio.is-visible .portfolio-card:nth-child(2),
.reveal-ready footer.is-visible .contact-link:nth-child(2) {
  transition-delay: 80ms;
}

.reveal-ready #services.is-visible .service-tile:nth-child(3),
.reveal-ready #workflow.is-visible .workflow-step-card:nth-child(3),
.reveal-ready #portfolio.is-visible .portfolio-card:nth-child(3),
.reveal-ready footer.is-visible .contact-link:nth-child(3) {
  transition-delay: 160ms;
}

.reveal-ready #portfolio.is-visible .portfolio-card:nth-child(4) {
  transition-delay: 240ms;
}

.service-tile::after,
.workflow-step-card::after,
.portfolio-card::after {
  position: absolute;
  left: 1.5rem;
  right: 1.5rem;
  top: 0;
  height: 3px;
  content: "";
  border-radius: 0 0 999px 999px;
  background: #2d63fc;
  opacity: 0;
  transition: opacity 260ms ease;
}

.service-tile:hover,
.workflow-step-card:hover,
.portfolio-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 18px 48px rgba(39, 39, 39, 0.07);
}

.service-tile:hover::after,
.workflow-step-card:hover::after,
.portfolio-card:hover::after {
  opacity: 0.72;
}

.service-tile h3,
.workflow-step-card h3,
.portfolio-card h3 {
  transition: color 240ms ease;
}

.service-tile:hover h3,
.workflow-step-card:hover h3,
.portfolio-card:hover h3 {
  color: #2d63fc;
}

.contact-link span {
  color: #2d63fc;
}

.contact-link:hover span {
  color: #f1f8ff;
}


.services-bento {
  position: relative;
  overflow: hidden;
}

.services-bento::before {
  position: absolute;
  inset: 0;
  content: "";
  pointer-events: none;
  background:
    radial-gradient(circle at 16% 12%, rgba(45, 99, 252, 0.16), transparent 28%),
    linear-gradient(90deg, rgba(241, 248, 255, 0.045) 1px, transparent 1px),
    linear-gradient(0deg, rgba(241, 248, 255, 0.04) 1px, transparent 1px);
  background-size: auto, 40px 40px, 40px 40px;
  opacity: 0.74;
}

.services-bento > * {
  position: relative;
  z-index: 1;
}

.service-bento-panel {
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(241, 248, 255, 0.04);
}

.service-bento-panel::after {
  position: absolute;
  inset: 0;
  content: "";
  pointer-events: none;
  background: linear-gradient(135deg, rgba(241, 248, 255, 0.055), transparent 38%);
  opacity: 0.72;
}

.service-bento-panel > * {
  position: relative;
  z-index: 1;
}

.service-bento-panel-interactive:hover {
  transform: translateY(-2px);
  box-shadow: 0 22px 56px rgba(0, 0, 0, 0.24), inset 0 1px 0 rgba(45, 99, 252, 0.2);
}

.service-chat-scene {
  display: grid;
  gap: 12px;
  max-width: 520px;
  padding-top: 54px;
}

.service-chat-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.service-chat-row-right {
  justify-content: flex-end;
  padding-right: 24px;
}

.service-avatar {
  display: grid;
  width: 30px;
  height: 30px;
  flex: 0 0 30px;
  place-items: center;
  border-radius: 999px;
  background: #f1f8ff;
  color: #272727;
  font-size: 11px;
  font-weight: 900;
}

.service-avatar-blue {
  background: #2d63fc;
  color: #f1f8ff;
}

.service-avatar-green {
  background: #19c689;
  color: #07110d;
}

.service-bubble {
  max-width: 78%;
  border-radius: 8px;
  background: rgba(241, 248, 255, 0.12);
  padding: 10px 14px;
  color: rgba(241, 248, 255, 0.9);
  font-size: 14px;
  font-weight: 700;
  line-height: 1.2;
}

.service-bubble-accent {
  background: rgba(45, 99, 252, 0.9);
  color: #f1f8ff;
}

.service-folder-scene {
  position: relative;
  min-height: 210px;
  display: grid;
  place-items: center;
  background:
    repeating-linear-gradient(0deg, transparent 0 19px, rgba(241, 248, 255, 0.08) 20px),
    linear-gradient(90deg, transparent, rgba(45, 99, 252, 0.13), transparent);
  mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent);
}

.service-folder-back,
.service-folder-front {
  position: absolute;
  border-radius: 9px;
  background: linear-gradient(180deg, #ffb000, #ff9500);
  box-shadow: 0 22px 38px rgba(255, 160, 0, 0.13);
}

.service-folder-back {
  width: 106px;
  height: 72px;
  transform: translate(-18px, -8px);
  opacity: 0.72;
}

.service-folder-front {
  display: flex;
  width: 132px;
  height: 82px;
  align-items: flex-start;
  justify-content: center;
  gap: 8px;
  padding-top: 14px;
  transform: translateY(14px);
}

.service-folder-front span {
  width: 30px;
  height: 36px;
  border-radius: 5px;
  background: rgba(241, 248, 255, 0.86);
  border: 2px solid rgba(45, 99, 252, 0.7);
}

.service-track-line {
  position: absolute;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(45, 99, 252, 0.8), transparent);
}

.service-track-line-one {
  width: 72%;
  transform: translateY(-16px);
}

.service-track-line-two {
  width: 54%;
  transform: translateY(34px);
  opacity: 0.7;
}

.service-stack-panel {
  background:
    linear-gradient(90deg, rgba(45, 99, 252, 0.12), transparent 28%),
    #0b0b0b;
}

.service-tools-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.service-tool-pill,
.service-check-pill {
  min-height: 48px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  border: 1px solid rgba(241, 248, 255, 0.1);
  padding: 11px 14px;
  font-size: 13px;
  font-weight: 850;
  line-height: 1.1;
}

.service-tool-pill {
  background: rgba(241, 248, 255, 0.08);
  color: rgba(241, 248, 255, 0.9);
}

.service-check-pill {
  background: rgba(45, 99, 252, 0.1);
  color: rgba(241, 248, 255, 0.68);
}

@media (max-width: 767px) {
  .service-chat-scene {
    padding-top: 10px;
  }

  .service-tools-grid {
    grid-template-columns: 1fr;
  }
}


.services-white-grid {
  opacity: 0.7;
  mix-blend-mode: screen;
}

.workflow-bento {
  position: relative;
  overflow: hidden;
}

.workflow-bento::before {
  position: absolute;
  inset: 0;
  content: "";
  pointer-events: none;
  background:
    radial-gradient(circle at 84% 18%, rgba(45, 99, 252, 0.18), transparent 28%),
    linear-gradient(90deg, rgba(241, 248, 255, 0.045) 1px, transparent 1px),
    linear-gradient(0deg, rgba(241, 248, 255, 0.04) 1px, transparent 1px);
  background-size: auto, 40px 40px, 40px 40px;
  opacity: 0.72;
}

.workflow-bento > * {
  position: relative;
  z-index: 1;
}

.workflow-bento-panel {
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(241, 248, 255, 0.04);
}

.workflow-bento-panel::after {
  position: absolute;
  inset: 0;
  content: "";
  pointer-events: none;
  background: linear-gradient(135deg, rgba(241, 248, 255, 0.055), transparent 38%);
  opacity: 0.72;
}

.workflow-bento-panel > * {
  position: relative;
  z-index: 1;
}

.workflow-bento-panel-interactive:hover {
  transform: translateY(-2px);
  box-shadow: 0 22px 56px rgba(0, 0, 0, 0.24), inset 0 1px 0 rgba(45, 99, 252, 0.2);
}

.workflow-brief-scene,
.workflow-design-scene {
  position: relative;
  min-height: 210px;
  overflow: hidden;
  border-radius: 8px;
  background:
    repeating-linear-gradient(0deg, transparent 0 19px, rgba(241, 248, 255, 0.07) 20px),
    linear-gradient(90deg, transparent, rgba(45, 99, 252, 0.11), transparent);
  mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
}

.workflow-note-card {
  position: absolute;
  border: 1px solid rgba(241, 248, 255, 0.12);
  border-radius: 8px;
  background: rgba(241, 248, 255, 0.1);
  color: rgba(241, 248, 255, 0.9);
}

.workflow-note-card-main {
  left: 12%;
  top: 52px;
  display: grid;
  width: 160px;
  height: 104px;
  align-content: center;
  gap: 10px;
  padding: 18px;
}

.workflow-note-card-main span {
  width: fit-content;
  border-radius: 6px;
  background: #2d63fc;
  padding: 6px 9px;
  font-size: 12px;
  font-weight: 900;
  line-height: 1;
}

.workflow-note-card-main strong {
  font-size: 24px;
  line-height: 1;
}

.workflow-note-card-small {
  right: 14%;
  top: 86px;
  padding: 12px 16px;
  font-size: 13px;
  font-weight: 850;
}

.workflow-note-card-line {
  left: 28%;
  right: 18%;
  top: 128px;
  height: 1px;
  border: 0;
  background: linear-gradient(90deg, transparent, rgba(45, 99, 252, 0.8), transparent);
}

.workflow-design-scene {
  display: grid;
  place-items: center;
}

.workflow-design-dot {
  position: absolute;
  width: 18px;
  height: 18px;
  border-radius: 999px;
  background: #2d63fc;
  opacity: 0.84;
}

.workflow-design-dot:nth-child(1) {
  left: 18%;
  top: 32%;
}

.workflow-design-dot:nth-child(2) {
  right: 20%;
  top: 24%;
  background: #f1f8ff;
}

.workflow-design-dot:nth-child(3) {
  right: 26%;
  bottom: 26%;
  background: #ffb000;
}

.workflow-design-window {
  display: grid;
  width: min(72%, 280px);
  gap: 10px;
  border-radius: 10px;
  border: 1px solid rgba(241, 248, 255, 0.12);
  background: rgba(241, 248, 255, 0.08);
  padding: 22px;
}

.workflow-design-window i {
  display: block;
  height: 10px;
  border-radius: 999px;
  background: rgba(241, 248, 255, 0.28);
}

.workflow-design-window i:nth-child(1) {
  width: 70%;
  background: #2d63fc;
}

.workflow-design-window i:nth-child(2) {
  width: 92%;
}

.workflow-design-window i:nth-child(3) {
  width: 56%;
  background: rgba(255, 176, 0, 0.72);
}

.workflow-design-window i:nth-child(4) {
  width: 82%;
}

.workflow-final-panel {
  background:
    linear-gradient(90deg, rgba(45, 99, 252, 0.12), transparent 28%),
    #0b0b0b;
}

.workflow-meta-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.workflow-meta-pill {
  min-height: 48px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  border: 1px solid rgba(241, 248, 255, 0.1);
  background: rgba(241, 248, 255, 0.08);
  padding: 11px 14px;
  color: rgba(241, 248, 255, 0.82);
  font-size: 13px;
  font-weight: 850;
  line-height: 1.1;
}

@media (max-width: 767px) {
  .workflow-meta-grid {
    grid-template-columns: 1fr;
  }

  .workflow-note-card-main {
    left: 8%;
  }

  .workflow-note-card-small {
    right: 8%;
  }
}

.footer-grid {
  opacity: 0.52;
}

main,
footer {
  position: relative;
  z-index: 1;
}

.toolbar-link {
  color: rgba(241, 248, 255, 0.72);
}

.toolbar-link:hover {
  background: rgba(241, 248, 255, 0.12);
  color: #f1f8ff;
}

.toolbar-link[data-active="true"] {
  background: #f1f8ff;
  color: #272727;
}

.accent-swipe {
  position: relative;
  display: inline-block;
  z-index: 0;
  color: #272727;
  white-space: nowrap;
}

.accent-swipe::before {
  position: absolute;
  z-index: -1;
  left: -0.08em;
  right: -0.1em;
  bottom: 0.02em;
  height: 0.78em;
  content: "";
  background: #2d63fc;
  clip-path: polygon(0 18%, 100% 5%, 98% 92%, 2% 82%);
  transform: rotate(1.4deg);
}

.accent-swipe-small::before {
  bottom: -0.02em;
  height: 0.9em;
  transform: rotate(-1.2deg);
}

.niche-rotator {
  position: relative;
  display: inline-block;
  height: 1.1em;
  min-width: 5.45em;
  overflow: hidden;
  color: #2d63fc;
  vertical-align: baseline;
  transform: translateY(0.02em);
  clip-path: inset(-0.12em 0 -0.12em 0);
  contain: paint;
}

.niche-track {
  position: absolute;
  inset: 0;
  display: block;
}

.niche-word {
  position: absolute;
  left: 0;
  top: 0;
  display: block;
  line-height: 1.04;
  opacity: 0;
  transform: translateY(0.22em);
  animation: niche-word 5.4s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  white-space: nowrap;
  will-change: opacity, transform, filter;
}

.niche-word:nth-child(2) {
  animation-delay: 1.8s;
}

.niche-word:nth-child(3) {
  animation-delay: 3.6s;
}

@keyframes niche-word {
  0% {
    opacity: 0;
    transform: translateY(0.22em);
    filter: blur(12px);
  }
  9%, 30% {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
  42%, 100% {
    opacity: 0;
    transform: translateY(-0.2em);
    filter: blur(12px);
  }
}

.hero-title-line {
  display: flex;
  align-items: flex-end;
  gap: 0.2em;
  line-height: 1.04;
  padding-bottom: 0.02em;
}

.hero-static-word {
  line-height: 1.04;
}

.hero-photo-wrap {
  margin-right: clamp(-8rem, -7vw, -2rem);
}

.hero-photo {
  filter: drop-shadow(0 38px 36px rgba(45, 99, 252, 0.2));
}

@media (max-width: 1023px) {
  .hero-photo-wrap {
    margin-right: 0;
  }
}

.reveal-ready section,
.reveal-ready footer,
.reveal-ready .reveal-blur {
  opacity: 0;
  filter: blur(10px);
  transform: translateY(20px);
  transition: opacity 680ms ease, filter 760ms ease, transform 760ms cubic-bezier(0.2, 0.82, 0.16, 1);
}

.reveal-ready section.is-visible,
.reveal-ready footer.is-visible,
.reveal-ready .reveal-blur.is-visible {
  opacity: 1;
  filter: blur(0);
  transform: translateY(0) scale(1);
}

@media (max-width: 520px) {
  .accent-swipe {
    white-space: normal;
  }
}

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }

  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 0.01ms !important;
  }
}

.services-section {
  min-height: 100vh;
  margin: 0;
  border: 1px solid rgba(19, 19, 19, 0.92);
  border-radius: 28px;
  background:
    linear-gradient(180deg, rgba(45, 99, 252, 0.1), transparent 34%),
    #050505;
  color: #f1f8ff;
  box-shadow:
    inset 0 1px 0 rgba(241, 248, 255, 0.08),
    0 26px 80px rgba(19, 19, 19, 0.16);
}

.services-section .section-heading h2 {
  color: #f1f8ff;
}

.services-section .section-heading p:last-child {
  color: rgba(241, 248, 255, 0.62);
}

.services-section .services-bento {
  border-radius: 20px;
  border: 1px solid rgba(241, 248, 255, 0.12);
  background: rgba(8, 8, 8, 0.92);
  padding: 12px;
}

@media (max-width: 767px) {
  .services-section {
    margin: 0;
    border-radius: 22px;
  }
}


/* Revision: unified dark frame, calmer hero text, minimal gallery */
.hero-word-line {
  line-height: 0.9;
}

.hero-word-rotator {
  position: relative;
  display: inline-block;
  width: 5.8em;
  height: 0.96em;
  overflow: hidden;
  color: #2d63fc;
  line-height: 0.9;
  vertical-align: baseline;
  clip-path: inset(-0.08em 0 -0.12em 0);
}

.hero-word-rotator > span {
  position: absolute;
  left: 0;
  top: 0;
  display: block;
  width: 100%;
  line-height: 0.9;
  opacity: 0;
  transform: translateY(0.42em);
  animation: hero-word-cycle 6.3s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  white-space: nowrap;
  will-change: opacity, transform, filter;
}

.hero-word-rotator > span:nth-child(2) {
  animation-delay: 2.1s;
}

.hero-word-rotator > span:nth-child(3) {
  animation-delay: 4.2s;
}

@keyframes hero-word-cycle {
  0% {
    opacity: 0;
    transform: translateY(0.42em);
    filter: blur(10px);
  }
  12%, 30% {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
  42%, 100% {
    opacity: 0;
    transform: translateY(-0.38em);
    filter: blur(10px);
  }
}

.dark-studio-frame {
  position: relative;
  isolation: isolate;
  /* clip, not hidden: hidden creates a scroll container and breaks position: sticky inside */
  overflow: clip;
  margin: 0;
  border: 1px solid rgba(241, 248, 255, 0.18);
  border-radius: 34px;
  background: #050505;
  color: #f1f8ff;
  box-shadow:
    inset 0 1px 0 rgba(241, 248, 255, 0.08),
    0 30px 90px rgba(19, 19, 19, 0.18);
}

.dark-studio-grid {
  opacity: 0.62;
  mix-blend-mode: screen;
}

.dark-studio-frame > section,
.dark-studio-frame > .workflow-section {
  position: relative;
  z-index: 1;
}

.dark-studio-frame .section-heading h2,
.dark-studio-frame .gallery-section h2,
.dark-studio-frame .workflow-section h2 {
  color: #f1f8ff !important;
}

.dark-studio-frame .section-heading p:last-child,
.dark-studio-frame .gallery-section p,
.dark-studio-frame .workflow-section p {
  color: rgba(241, 248, 255, 0.62) !important;
}

.services-section {
  min-height: auto;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.services-section .services-bento {
  overflow: visible;
  border: 0;
  border-radius: 0;
  background: transparent;
  padding: 0;
}

.services-bento::before {
  display: none;
}

.service-brand-scene,
.service-artist-scene {
  position: relative;
  min-height: 220px;
  perspective: 900px;
  transform-style: preserve-3d;
}

.service-brand-board {
  position: absolute;
  left: 8%;
  top: 20px;
  display: grid;
  width: min(56%, 360px);
  height: 160px;
  gap: 13px;
  border: 1px solid rgba(241, 248, 255, 0.16);
  border-radius: 14px;
  background: linear-gradient(145deg, rgba(241, 248, 255, 0.14), rgba(241, 248, 255, 0.04));
  padding: 22px;
  transform: rotateX(58deg) rotateZ(-9deg);
  transform-style: preserve-3d;
  animation: service-float-a 6s ease-in-out infinite;
  box-shadow: 0 28px 70px rgba(45, 99, 252, 0.12);
}

.service-brand-board span {
  display: block;
  height: 12px;
  border-radius: 999px;
  background: rgba(241, 248, 255, 0.26);
}

.service-brand-board .service-brand-board-bar {
  width: 42%;
  background: #2d63fc;
}

.service-brand-board .service-brand-board-line-long {
  width: 82%;
}

.service-brand-board .service-brand-board-line {
  width: 64%;
}

.service-brand-board .service-brand-board-chip {
  display: inline-grid;
  width: fit-content;
  height: auto;
  place-items: center;
  border-radius: 7px;
  background: rgba(45, 99, 252, 0.2);
  padding: 8px 12px;
  color: #f1f8ff;
  font-size: 11px;
  font-weight: 900;
  line-height: 1;
}

.service-brand-rollup {
  position: absolute;
  right: 13%;
  top: 18px;
  width: 108px;
  height: 180px;
  border: 1px solid rgba(241, 248, 255, 0.14);
  border-radius: 18px;
  background: linear-gradient(180deg, #f1f8ff, #819cff 54%, #2d63fc);
  transform: rotateY(-28deg) rotateX(12deg) rotateZ(5deg);
  transform-style: preserve-3d;
  animation: service-float-b 5.4s ease-in-out infinite;
  box-shadow: 18px 26px 60px rgba(0, 0, 0, 0.32);
}

.service-brand-rollup span {
  position: absolute;
  left: 18px;
  right: 18px;
  height: 10px;
  border-radius: 999px;
  background: rgba(5, 5, 5, 0.28);
}

.service-brand-rollup span:first-child {
  top: 28px;
}

.service-brand-rollup span:last-child {
  bottom: 30px;
}

.service-brand-card {
  position: absolute;
  left: 34%;
  top: 118px;
  border-radius: 10px;
  background: #f1f8ff;
  padding: 14px 18px;
  color: #050505;
  font-size: 12px;
  font-weight: 950;
  text-transform: uppercase;
  transform: rotateX(50deg) rotateZ(7deg) translateZ(36px);
  animation: service-float-c 6.4s ease-in-out infinite;
}

.service-vinyl {
  position: absolute;
  left: 12%;
  top: 24px;
  width: 170px;
  height: 170px;
  border-radius: 50%;
  background:
    radial-gradient(circle, #f1f8ff 0 11px, #2d63fc 12px 25px, transparent 26px),
    repeating-radial-gradient(circle, #111 0 8px, #272727 9px 11px);
  transform: rotateX(56deg) rotateZ(-18deg);
  animation: service-spin 9s linear infinite;
  box-shadow: 0 34px 70px rgba(0, 0, 0, 0.36);
}

.service-cover-stack {
  position: absolute;
  right: 12%;
  top: 42px;
  width: 150px;
  height: 150px;
  border-radius: 16px;
  border: 1px solid rgba(241, 248, 255, 0.14);
  transform-style: preserve-3d;
}

.service-cover-stack-back {
  background: rgba(241, 248, 255, 0.12);
  transform: rotateY(-28deg) rotateX(16deg) translateX(-28px) translateY(18px);
}

.service-cover-stack-mid {
  background: linear-gradient(135deg, rgba(45, 99, 252, 0.9), rgba(241, 248, 255, 0.12));
  transform: rotateY(-24deg) rotateX(16deg) translateX(-10px) translateY(7px);
  animation: service-float-b 5.8s ease-in-out infinite;
}

.service-cover-stack-front {
  display: grid;
  place-items: end start;
  background:
    linear-gradient(145deg, rgba(241, 248, 255, 0.2), transparent 35%),
    #2d63fc;
  padding: 18px;
  transform: rotateY(-20deg) rotateX(16deg) translateZ(34px);
  animation: service-float-a 5.5s ease-in-out infinite;
}

.service-cover-stack-front span {
  color: #f1f8ff;
  font-size: 30px;
  font-weight: 950;
  line-height: 1;
}

.service-artist-tag {
  position: absolute;
  left: 34%;
  top: 164px;
  border-radius: 999px;
  background: #f1f8ff;
  padding: 10px 14px;
  color: #050505;
  font-size: 11px;
  font-weight: 950;
  text-transform: uppercase;
  transform: rotate(-5deg);
}

@keyframes service-float-a {
  0%, 100% { transform: rotateX(58deg) rotateZ(-9deg) translateY(0); }
  50% { transform: rotateX(58deg) rotateZ(-9deg) translateY(-12px); }
}

@keyframes service-float-b {
  0%, 100% { translate: 0 0; }
  50% { translate: 0 -14px; }
}

@keyframes service-float-c {
  0%, 100% { translate: 0 0; }
  50% { translate: 0 -8px; }
}

@keyframes service-spin {
  to { rotate: 0 0 1 360deg; }
}

.gallery-section .accent-swipe::before,
.gallery-section .h-px,
.gallery-filter-row,
.gallery-image-shade,
.gallery-project-index {
  display: none !important;
}

.gallery-section {
  color: #f1f8ff;
}

.gallery-section .accent-swipe {
  color: #f1f8ff;
}

.gallery-shell {
  border: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  padding: 0 !important;
}

.gallery-showcase {
  display: grid !important;
  grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
  gap: 18px !important;
}

.gallery-showcase > .grid {
  display: contents !important;
}

.gallery-feature-card,
.gallery-side-card {
  display: flex !important;
  min-width: 0;
  flex-direction: column;
  gap: 18px !important;
  border: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  padding: 0 !important;
  box-shadow: none !important;
}

.gallery-feature-card .relative,
.gallery-side-card .relative {
  aspect-ratio: 4 / 5 !important;
  border-radius: 14px !important;
  border: 1px solid rgba(241, 248, 255, 0.12);
}

.gallery-feature-card h3,
.gallery-side-card h3 {
  margin-top: 10px !important;
  color: #f1f8ff;
  font-size: clamp(20px, 2vw, 30px) !important;
  line-height: 1.05 !important;
}

.gallery-feature-card p,
.gallery-side-card p {
  color: rgba(241, 248, 255, 0.55) !important;
}

.gallery-feature-card > div:last-child,
.gallery-side-card > div:last-child {
  display: block !important;
  min-height: 0 !important;
  padding: 0 !important;
}

.gallery-feature-card > div:last-child > p,
.gallery-scope-chip {
  display: none !important;
}

.portfolio-card::after {
  display: none !important;
}

@media (max-width: 1023px) {
  .gallery-showcase {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  }
}

@media (max-width: 640px) {
  .dark-studio-frame {
    border-radius: 24px;
  }

  .gallery-showcase {
    grid-template-columns: 1fr !important;
  }

  .hero-word-rotator {
    width: 6.4em;
  }
}

/* Final visual cleanup: calmer hero, unified frame, minimal portfolio */
.hero-kinetic-stage {
  position: absolute;
  inset: 12% 3% auto auto;
  z-index: 0;
  width: min(42vw, 440px);
  aspect-ratio: 1;
  perspective: 900px;
  transform-style: preserve-3d;
  opacity: 0.9;
}

.hero-kinetic-plane,
.hero-kinetic-cube {
  position: absolute;
  display: block;
  transform-style: preserve-3d;
  will-change: transform;
}

.hero-kinetic-plane {
  border: 1px solid rgba(45, 99, 252, 0.28);
  border-radius: 18px;
  background:
    linear-gradient(90deg, rgba(45, 99, 252, 0.16) 1px, transparent 1px),
    linear-gradient(0deg, rgba(45, 99, 252, 0.14) 1px, transparent 1px),
    rgba(241, 248, 255, 0.46);
  background-size: 22px 22px;
  box-shadow: 0 30px 80px rgba(45, 99, 252, 0.12);
}

.hero-kinetic-plane-one {
  inset: 18% 10% 18% 10%;
  transform: rotateX(62deg) rotateZ(-18deg);
  animation: hero-kinetic-float-a 7s ease-in-out infinite;
}

.hero-kinetic-plane-two {
  inset: 25% 26% 28% 2%;
  background-color: rgba(45, 99, 252, 0.08);
  transform: rotateX(58deg) rotateZ(12deg) translateZ(52px);
  animation: hero-kinetic-float-b 6.2s ease-in-out infinite;
}

.hero-kinetic-plane-three {
  inset: 8% 2% 46% 48%;
  background-color: rgba(241, 248, 255, 0.62);
  transform: rotateY(-34deg) rotateX(18deg) rotateZ(8deg) translateZ(86px);
  animation: hero-kinetic-float-c 5.8s ease-in-out infinite;
}

.hero-kinetic-cube {
  right: 24%;
  bottom: 23%;
  width: 68px;
  height: 68px;
  border: 1px solid rgba(241, 248, 255, 0.72);
  border-radius: 14px;
  background: #2d63fc;
  transform: rotateX(58deg) rotateZ(-28deg) translateZ(110px);
  animation: hero-kinetic-cube 6.8s ease-in-out infinite;
  box-shadow: 0 24px 54px rgba(45, 99, 252, 0.32);
}

@keyframes hero-kinetic-float-a {
  0%, 100% { transform: rotateX(62deg) rotateZ(-18deg) translateY(0); }
  50% { transform: rotateX(62deg) rotateZ(-18deg) translateY(-16px); }
}

@keyframes hero-kinetic-float-b {
  0%, 100% { transform: rotateX(58deg) rotateZ(12deg) translateZ(52px) translateY(0); }
  50% { transform: rotateX(58deg) rotateZ(12deg) translateZ(52px) translateY(18px); }
}

@keyframes hero-kinetic-float-c {
  0%, 100% { transform: rotateY(-34deg) rotateX(18deg) rotateZ(8deg) translateZ(86px) translateY(0); }
  50% { transform: rotateY(-34deg) rotateX(18deg) rotateZ(8deg) translateZ(86px) translateY(-14px); }
}

@keyframes hero-kinetic-cube {
  0%, 100% { transform: rotateX(58deg) rotateZ(-28deg) translateZ(110px) translateY(0); }
  50% { transform: rotateX(58deg) rotateZ(-18deg) translateZ(110px) translateY(-18px); }
}

.dark-studio-frame {
  border-color: rgba(241, 248, 255, 0.64);
  border-radius: 34px;
}

.dark-studio-grid {
  opacity: 0.78;
}

.services-section .services-bento,
.workflow-bento,
.gallery-shell {
  border: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
}

.gallery-section h2 {
  max-width: none;
}

.gallery-showcase {
  margin-top: 0 !important;
  align-items: start;
}

.gallery-feature-card .relative,
.gallery-side-card .relative {
  overflow: hidden;
  background: rgba(241, 248, 255, 0.06) !important;
}

.gallery-feature-card img,
.gallery-side-card img {
  filter: grayscale(1) contrast(1.02);
}

.gallery-feature-card:hover img,
.gallery-side-card:hover img {
  filter: grayscale(0) contrast(1);
}

.service-brand-scene,
.service-artist-scene {
  margin-bottom: 1.5rem;
}

@media (max-width: 1023px) {
  .hero-kinetic-stage {
    inset: 7% 50% auto auto;
    width: min(72vw, 380px);
    transform: translateX(50%);
  }
}

@media (max-width: 640px) {
  .hero-title {
    overflow-wrap: anywhere;
  }

  .hero-kinetic-stage {
    top: 10%;
    width: min(86vw, 320px);
    opacity: 0.62;
  }
}

/* User revision: typing hero, no 3D objects, modal gallery, stacked workflow */
.hero-typing-line {
  min-height: 0.96em;
  white-space: nowrap;
}

.hero-typed-word {
  display: inline-block;
  min-width: 4.72em;
}

.hero-typing-cursor {
  display: inline-block;
  width: 0.055em;
  height: 0.74em;
  margin-left: 0.07em;
  border-radius: 999px;
  background: #2d63fc;
  transform: translateY(0.08em);
  animation: hero-cursor-blink 0.9s steps(2, jump-none) infinite;
}

@keyframes hero-cursor-blink {
  0%, 45% { opacity: 1; }
  46%, 100% { opacity: 0; }
}

.hero-kinetic-stage,
.service-brand-scene,
.service-artist-scene,
.service-brand-board,
.service-brand-rollup,
.service-brand-card,
.service-vinyl,
.service-cover-stack,
.service-artist-tag {
  display: none !important;
}

.service-copy-block {
  display: flex;
  min-height: 360px;
  flex-direction: column;
  justify-content: flex-end;
}

.service-bento-panel {
  background:
    linear-gradient(135deg, rgba(241, 248, 255, 0.075), transparent 42%),
    linear-gradient(90deg, rgba(45, 99, 252, 0.18) 0 1px, transparent 1px),
    #131313 !important;
  background-size: auto, 34px 34px, auto;
}

.gallery-feature-card,
.gallery-side-card {
  cursor: pointer;
  color: inherit;
  font: inherit;
}

.gallery-feature-card .relative,
.gallery-side-card .relative {
  display: block;
}

.portfolio-modal {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: grid;
  place-items: center;
  padding: 20px;
}

.portfolio-modal-backdrop {
  position: absolute;
  inset: 0;
  border: 0;
  background: rgba(5, 5, 5, 0.72);
  backdrop-filter: blur(18px);
  animation: portfolio-backdrop-in 360ms ease both;
}

@keyframes portfolio-backdrop-in {
  from {
    opacity: 0;
    backdrop-filter: blur(0);
  }
  to {
    opacity: 1;
    backdrop-filter: blur(18px);
  }
}

.portfolio-modal-panel {
  position: relative;
  z-index: 1;
  width: min(1120px, 100%);
  max-height: min(86vh, 820px);
  overflow: hidden;
  border: 1px solid rgba(241, 248, 255, 0.18);
  border-radius: var(--radius-block);
  background: #0b0b0b;
  color: #f1f8ff;
  box-shadow: 0 40px 120px rgba(0, 0, 0, 0.52);
  animation: portfolio-modal-in 420ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.portfolio-modal-scroll {
  display: grid;
  max-height: min(86vh, 820px);
  overflow-y: auto;
  overscroll-behavior: contain;
}

.portfolio-modal-media {
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid rgba(241, 248, 255, 0.12);
  background: rgba(241, 248, 255, 0.05);
}

.portfolio-modal-media img {
  animation: portfolio-modal-media-in 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.portfolio-modal-close-x {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 2;
  display: grid;
  width: 42px;
  height: 42px;
  place-items: center;
  border: 1px solid rgba(241, 248, 255, 0.16);
  border-radius: 999px;
  background: rgba(11, 11, 11, 0.62);
  color: #f1f8ff;
  font-size: 20px;
  line-height: 1;
  backdrop-filter: blur(10px);
  transition: background-color 220ms ease, color 220ms ease, transform 220ms ease;
}

.portfolio-modal-close-x:hover,
.portfolio-modal-close-x:focus-visible {
  background: #2d63fc;
  transform: rotate(90deg);
  outline: none;
}

.portfolio-modal-meta {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  border-top: 1px solid rgba(241, 248, 255, 0.1);
  padding-top: 20px;
}

.portfolio-modal-meta div {
  display: grid;
  gap: 6px;
}

.portfolio-modal-meta dt {
  color: rgba(241, 248, 255, 0.5);
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.04em;
  line-height: 1;
  text-transform: uppercase;
}

.portfolio-modal-meta dd {
  color: #f1f8ff;
  font-size: 14px;
  font-weight: 800;
  line-height: 1.25;
}

@media (max-width: 560px) {
  .portfolio-modal-meta {
    grid-template-columns: 1fr;
    gap: 14px;
  }
}

@keyframes portfolio-modal-media-in {
  from {
    opacity: 0;
    transform: scale(1.06);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.portfolio-modal-copy {
  display: grid;
  gap: 18px;
  padding: clamp(22px, 4vw, 44px);
}

.portfolio-modal-copy h3 {
  max-width: 780px;
  color: #f1f8ff;
  font-size: clamp(34px, 5vw, 72px);
  font-weight: 950;
  line-height: 0.98;
}

.portfolio-modal-copy p {
  max-width: 68ch;
  color: rgba(241, 248, 255, 0.68);
  font-size: 16px;
  font-weight: 600;
  line-height: 1.65;
}

.portfolio-modal-chip {
  display: inline-flex;
  min-height: 34px;
  align-items: center;
  border: 1px solid rgba(241, 248, 255, 0.14);
  border-radius: 8px;
  background: rgba(241, 248, 255, 0.08);
  padding: 8px 11px;
  color: rgba(241, 248, 255, 0.84);
  font-size: 12px;
  font-weight: 900;
  line-height: 1;
  text-transform: uppercase;
}

.portfolio-modal-close {
  width: fit-content;
  min-height: 46px;
  border: 0;
  border-radius: 8px;
  background: #f1f8ff;
  padding: 0 18px;
  color: #131313;
  font-size: 13px;
  font-weight: 900;
  transition: background-color 220ms ease, color 220ms ease;
}

.portfolio-modal-close:hover,
.portfolio-modal-close:focus-visible {
  background: #2d63fc;
  color: #f1f8ff;
  outline: none;
}

@keyframes portfolio-modal-in {
  from {
    opacity: 0;
    transform: translateY(18px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.workflow-sticky-layout {
  align-items: start;
}

.workflow-sticky-heading {
  position: sticky;
  top: 112px;
  padding-top: 4px;
}

.workflow-stack {
  display: grid;
  gap: 26px;
  padding-bottom: 18vh;
}

.workflow-stack-card {
  position: sticky;
  top: 112px;
  display: flex;
  min-height: 430px;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  border: 1px solid rgba(241, 248, 255, 0.14);
  border-radius: 18px;
  background:
    linear-gradient(135deg, rgba(45, 99, 252, 0.24), transparent 34%),
    #0b0b0b;
  padding: clamp(24px, 4vw, 42px);
  color: #f1f8ff;
  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.24);
}

.workflow-stack-card:nth-child(2) {
  top: 138px;
}

.workflow-stack-card:nth-child(3) {
  top: 164px;
}

.workflow-stack-card::before {
  position: absolute;
  inset: 0;
  content: "";
  pointer-events: none;
  background:
    linear-gradient(90deg, rgba(241, 248, 255, 0.06) 1px, transparent 1px),
    linear-gradient(0deg, rgba(241, 248, 255, 0.05) 1px, transparent 1px);
  background-size: 32px 32px;
  mask-image: linear-gradient(180deg, #000, transparent 78%);
}

.workflow-stack-card > * {
  position: relative;
  z-index: 1;
}

.workflow-card-topline,
.workflow-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  color: rgba(241, 248, 255, 0.58);
  font-size: 12px;
  font-weight: 950;
  line-height: 1;
  text-transform: uppercase;
}

.workflow-stack-card h3 {
  max-width: 760px;
  color: #f1f8ff;
  font-size: clamp(42px, 6vw, 92px);
  font-weight: 950;
  line-height: 0.96;
}

.workflow-stack-card p {
  margin-top: 24px;
  max-width: 58ch;
  color: rgba(241, 248, 255, 0.68) !important;
  font-size: clamp(16px, 1.7vw, 20px);
  font-weight: 650;
  line-height: 1.55;
}

.workflow-stack-cta {
  display: inline-flex;
  width: fit-content;
  min-height: 52px;
  align-items: center;
  gap: 10px;
  border-radius: 8px;
  background: #f1f8ff;
  padding: 0 18px;
  color: #131313;
  font-size: 13px;
  font-weight: 900;
  transition: background-color 220ms ease, color 220ms ease;
}

.workflow-stack-cta span {
  display: grid;
  width: 24px;
  height: 24px;
  place-items: center;
  border-radius: 6px;
  background: #2d63fc;
  color: #f1f8ff;
}

.workflow-stack-cta:hover,
.workflow-stack-cta:focus-visible {
  background: #2d63fc;
  color: #f1f8ff;
  outline: none;
}

.reveal-ready section,
.reveal-ready footer {
  opacity: 0;
  filter: blur(16px);
  transform: translateY(44px) scale(0.975);
  transition:
    opacity 900ms cubic-bezier(0.16, 1, 0.3, 1),
    filter 1000ms cubic-bezier(0.16, 1, 0.3, 1),
    transform 1100ms cubic-bezier(0.16, 1, 0.3, 1);
  will-change: opacity, transform, filter;
}

.reveal-ready section.is-visible,
.reveal-ready footer.is-visible {
  opacity: 1;
  filter: blur(0);
  transform: translateY(0) scale(1);
}

/* Premium staged reveal for cards / panels inside a section */
.reveal-ready .service-bento-panel,
.reveal-ready .portfolio-card,
.reveal-ready .workflow-stack-card,
.reveal-ready .contact-link {
  opacity: 0;
  filter: blur(10px);
  transform: translateY(34px) scale(0.985);
  transition:
    opacity 720ms cubic-bezier(0.16, 1, 0.3, 1),
    filter 720ms cubic-bezier(0.16, 1, 0.3, 1),
    transform 860ms cubic-bezier(0.16, 1, 0.3, 1),
    border-color 260ms ease,
    box-shadow 260ms ease;
  will-change: opacity, transform, filter;
}

.reveal-ready #services.is-visible .service-bento-panel,
.reveal-ready #portfolio.is-visible .portfolio-card,
.reveal-ready #workflow.is-visible .workflow-stack-card,
.reveal-ready footer.is-visible .contact-link {
  opacity: 1;
  filter: blur(0);
  transform: translateY(0) scale(1);
}

.reveal-ready #services.is-visible .service-bento-panel:nth-child(2),
.reveal-ready #portfolio.is-visible .portfolio-card:nth-child(2),
.reveal-ready #workflow.is-visible .workflow-stack-card:nth-child(2),
.reveal-ready footer.is-visible .contact-link:nth-child(2) {
  transition-delay: 110ms;
}

.reveal-ready #portfolio.is-visible .portfolio-card:nth-child(3),
.reveal-ready #workflow.is-visible .workflow-stack-card:nth-child(3),
.reveal-ready footer.is-visible .contact-link:nth-child(3) {
  transition-delay: 220ms;
}

.reveal-ready #portfolio.is-visible .portfolio-card:nth-child(4) {
  transition-delay: 330ms;
}

@media (max-width: 1023px) {
  .workflow-sticky-heading {
    position: relative;
    top: auto;
  }

  .workflow-stack-card,
  .workflow-stack-card:nth-child(2),
  .workflow-stack-card:nth-child(3) {
    top: 92px;
  }
}

@media (max-width: 640px) {
  .hero-typed-word {
    min-width: 0;
  }

  .service-copy-block {
    min-height: 300px;
  }

  .portfolio-modal {
    padding: 10px;
  }

  .portfolio-modal-panel,
  .portfolio-modal-scroll {
    max-height: 88vh;
    border-radius: 14px;
  }

  .workflow-stack-card {
    min-height: 360px;
  }
}

/* Refinement: true Morphing Text hero + real workflow card overlap */
.hero-morph-line {
  white-space: nowrap;
}

.hero-morph-word-wrap {
  position: relative;
  display: inline-block;
  width: 4.85em;
  height: 0.94em;
  vertical-align: baseline;
  contain: paint;
}

.hero-morph-word {
  position: absolute;
  left: 0;
  top: 0;
  line-height: 0.94;
  opacity: 0;
  filter: blur(18px);
  transform: translateY(0.05em) scale(0.92);
  animation: hero-morph-word 7.2s ease-in-out infinite;
  animation-delay: calc(var(--word-index) * 2.4s);
  will-change: opacity, filter, transform;
}

@keyframes hero-morph-word {
  0% {
    opacity: 0;
    filter: blur(18px);
    transform: translateY(0.08em) scale(0.92);
  }
  10%, 26% {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0) scale(1);
  }
  38%, 100% {
    opacity: 0;
    filter: blur(18px);
    transform: translateY(-0.08em) scale(1.08);
  }
}

.workflow-stack {
  display: block;
  padding-bottom: 34vh;
}

.workflow-stack-card {
  top: 112px !important;
  z-index: 1;
  margin-bottom: 36vh;
  transform-origin: 50% 0;
}

.workflow-stack-card:nth-child(1) {
  z-index: 1;
}

.workflow-stack-card:nth-child(2) {
  z-index: 2;
}

.workflow-stack-card:nth-child(3) {
  z-index: 3;
}

.workflow-stack-card + .workflow-stack-card {
  margin-top: -210px;
}

.workflow-stack-cta {
  margin-top: -18vh;
}

.reveal-ready #workflow.is-visible .workflow-stack-card:nth-child(2),
.reveal-ready #workflow.is-visible .workflow-stack-card:nth-child(3) {
  transform: translateY(0);
}

@media (max-width: 1023px) {
  .workflow-stack-card,
  .workflow-stack-card:nth-child(2),
  .workflow-stack-card:nth-child(3) {
    top: 92px !important;
  }

  .workflow-stack-card + .workflow-stack-card {
    margin-top: -150px;
  }
}

@media (max-width: 640px) {
  .hero-morph-word-wrap {
    width: 4.9em;
  }

  .workflow-stack-card + .workflow-stack-card {
    margin-top: -110px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-morph-word {
    animation: none !important;
    opacity: 0;
    filter: none;
    transform: none;
  }

  .hero-morph-word:first-child {
    opacity: 1;
  }
}

/* Gemini instruction implementation: steps-section stacking cards */
.steps-section {
  /* Single source of truth: heading and cards pin at the same line */
  --steps-sticky-top: 104px;
  position: relative;
}

.steps-container {
  display: grid;
  grid-template-columns: minmax(240px, 0.36fr) minmax(0, 0.64fr);
  gap: clamp(36px, 7vw, 112px);
  align-items: start;
}

.steps-left {
  position: sticky;
  top: var(--steps-sticky-top);
  align-self: start;
  /* Nudge the heading slightly right, toward the cards */
  padding-left: clamp(18px, 3vw, 56px);
  padding-top: 0;
}

.steps-title {
  max-width: 520px;
  /* Cap-height sits level with the top edge of the first card */
  margin-top: -0.12em;
  color: #f1f8ff !important;
  font-size: clamp(54px, 6vw, 96px);
  font-weight: 950;
  line-height: 0.96;
  letter-spacing: 0;
}

.steps-kicker {
  margin-top: 20px;
  color: #2d63fc !important;
  font-size: 14px;
  font-weight: 900;
  line-height: 1;
  text-transform: uppercase;
}

.steps-description {
  margin-top: 20px;
  max-width: 42ch;
  color: rgba(241, 248, 255, 0.62) !important;
  font-size: 16px;
  font-weight: 650;
  line-height: 1.58;
}

.steps-right {
  position: relative;
  display: block;
  /* No trailing travel: once the 3rd card docks, the page scrolls on */
  padding-bottom: 0;
}

/* Sticky wrapper: framer-motion animates the card inside, wrapper handles pinning.
   All cards dock on the same line as the heading, so the 3rd card's top
   aligns with «Этапы работы» and the stack ends right there. */
.step-sticky {
  position: sticky;
  top: var(--steps-sticky-top);
}

.step-sticky + .step-sticky {
  margin-top: 32vh;
}

.step-card {
  display: flex;
  min-height: min(58vh, 520px);
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  border: 1px solid rgba(241, 248, 255, 0.16);
  border-radius: var(--radius-block);
  background:
    linear-gradient(135deg, rgba(45, 99, 252, 0.26), transparent 36%),
    linear-gradient(180deg, rgba(241, 248, 255, 0.08), rgba(241, 248, 255, 0.025)),
    #0b0b0b;
  padding: clamp(24px, 4vw, 44px);
  color: #f1f8ff;
  box-shadow: 0 34px 90px rgba(0, 0, 0, 0.28);
  transform-origin: top center;
}

.step-card::before {
  position: absolute;
  inset: 0;
  content: "";
  pointer-events: none;
  background:
    linear-gradient(90deg, rgba(241, 248, 255, 0.06) 1px, transparent 1px),
    linear-gradient(0deg, rgba(241, 248, 255, 0.05) 1px, transparent 1px);
  background-size: 32px 32px;
  mask-image: linear-gradient(180deg, #000, transparent 78%);
}

.step-card > * {
  position: relative;
  z-index: 1;
}

.step-card-topline,
.step-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  color: rgba(241, 248, 255, 0.58);
  font-size: 12px;
  font-weight: 950;
  line-height: 1;
  text-transform: uppercase;
}

.step-card h3 {
  max-width: 760px;
  color: #f1f8ff;
  font-size: clamp(42px, 6vw, 92px);
  font-weight: 950;
  line-height: 0.96;
  letter-spacing: 0;
}

.step-card p {
  margin-top: 24px;
  max-width: 58ch;
  color: rgba(241, 248, 255, 0.68) !important;
  font-size: clamp(16px, 1.7vw, 20px);
  font-weight: 650;
  line-height: 1.55;
}

.reveal-ready .step-sticky {
  opacity: 0;
  filter: blur(12px);
  transform: translateY(40px) scale(0.975);
  transition:
    opacity 820ms cubic-bezier(0.16, 1, 0.3, 1),
    filter 820ms cubic-bezier(0.16, 1, 0.3, 1),
    transform 980ms cubic-bezier(0.16, 1, 0.3, 1);
}

.reveal-ready #workflow.is-visible .step-sticky {
  opacity: 1;
  filter: blur(0);
  transform: translateY(0) scale(1);
}

.reveal-ready #workflow.is-visible .step-sticky:nth-child(2) {
  transition-delay: 120ms;
}

.reveal-ready #workflow.is-visible .step-sticky:nth-child(3) {
  transition-delay: 240ms;
}

@media (max-width: 1023px) {
  .steps-section {
    min-height: auto;
  }

  .steps-container {
    grid-template-columns: 1fr;
    gap: 34px;
  }

  .steps-left {
    position: relative;
    top: auto;
  }

  /* Mobile: no stacking — cards flow top to bottom with plain gaps */
  .steps-left {
    padding-left: 0;
  }

  .steps-right {
    padding-bottom: 0;
  }

  .step-sticky {
    position: relative;
    top: auto;
  }

  .step-sticky + .step-sticky {
    margin-top: 20px;
  }

  .step-card {
    min-height: 430px;
  }
}

@media (max-width: 640px) {
  .step-card {
    min-height: 360px;
    border-radius: 18px;
  }

  .step-sticky + .step-sticky {
    margin-top: 16px;
  }
}

/* ===== Premium unification: one radius system, one border system, one hover language ===== */
:root {
  --radius-media: 16px;
  --radius-chip: 10px;
  --border-soft: rgba(241, 248, 255, 0.12);
  --border-strong: rgba(241, 248, 255, 0.2);
}

.service-bento-panel {
  border-radius: var(--radius-block) !important;
  border-color: var(--border-soft) !important;
}

.service-bento-panel-interactive {
  transition:
    transform 340ms cubic-bezier(0.16, 1, 0.3, 1),
    border-color 260ms ease,
    box-shadow 340ms ease;
}

.service-bento-panel-interactive:hover {
  transform: translateY(-4px);
  border-color: rgba(45, 99, 252, 0.55) !important;
  box-shadow: 0 26px 64px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(45, 99, 252, 0.2);
}

.service-tool-pill,
.service-check-pill,
.portfolio-modal-chip,
.gallery-scope-chip,
.workflow-meta-pill {
  border-radius: var(--radius-chip);
}

/* ===== Gallery refresh: framed media, hover lift, arrow badge, soft shade ===== */
.gallery-note {
  margin-top: 18px;
  max-width: 52ch;
  color: rgba(19, 19, 19, 0.62);
  font-size: 16px;
  font-weight: 550;
  line-height: 1.55;
}

.dark-studio-frame .gallery-note {
  color: rgba(241, 248, 255, 0.62) !important;
}

.gallery-kicker {
  margin-bottom: 16px;
  color: #2d63fc !important;
  font-size: 14px;
  font-weight: 900;
  line-height: 1;
  text-transform: uppercase;
}

.gallery-feature-card .relative,
.gallery-side-card .relative {
  border-radius: var(--radius-media) !important;
  border: 1px solid var(--border-soft);
  transition:
    transform 420ms cubic-bezier(0.16, 1, 0.3, 1),
    border-color 300ms ease,
    box-shadow 420ms ease;
}

.gallery-feature-card:hover .relative,
.gallery-side-card:hover .relative {
  transform: translateY(-6px);
  border-color: rgba(45, 99, 252, 0.55);
  box-shadow: 0 26px 60px rgba(0, 0, 0, 0.42);
}

.gallery-feature-card .relative::before,
.gallery-side-card .relative::before {
  position: absolute;
  inset: 0;
  z-index: 1;
  content: "";
  background: linear-gradient(180deg, transparent 56%, rgba(5, 5, 5, 0.58));
  opacity: 0;
  transition: opacity 320ms ease;
  pointer-events: none;
}

.gallery-feature-card:hover .relative::before,
.gallery-side-card:hover .relative::before {
  opacity: 1;
}

.gallery-feature-card .relative::after,
.gallery-side-card .relative::after {
  position: absolute;
  right: 14px;
  top: 14px;
  z-index: 2;
  display: grid;
  width: 42px;
  height: 42px;
  place-items: center;
  content: "\2197";
  border-radius: 12px;
  background: #2d63fc;
  color: #f1f8ff;
  font-size: 18px;
  font-weight: 900;
  opacity: 0;
  transform: translateY(6px) scale(0.9);
  transition:
    opacity 300ms ease,
    transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
  pointer-events: none;
}

.gallery-feature-card:hover .relative::after,
.gallery-side-card:hover .relative::after {
  opacity: 1;
  transform: translateY(0) scale(1);
}

/* ===== Footer refresh ===== */
footer#contacts {
  border-radius: var(--radius-block);
}

.footer-kicker {
  margin-bottom: 16px;
  color: rgba(241, 248, 255, 0.72);
  font-size: 14px;
  font-weight: 900;
  line-height: 1;
  text-transform: uppercase;
}

.contact-link {
  display: flex;
  min-height: 88px;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  border-radius: var(--radius-media);
  background: #f1f8ff;
  padding: 20px 22px;
  color: #131313;
  transition:
    transform 320ms cubic-bezier(0.16, 1, 0.3, 1),
    background-color 260ms ease,
    color 260ms ease,
    box-shadow 320ms ease;
}

.contact-link:hover,
.contact-link:focus-visible {
  transform: translateY(-3px);
  background: #131313;
  color: #f1f8ff;
  box-shadow: 0 20px 48px rgba(5, 5, 5, 0.3);
  outline: none;
}

.contact-link-label {
  display: block;
  font-size: 20px;
  font-weight: 900;
  line-height: 1;
}

.contact-link-handle {
  display: block;
  margin-top: 8px;
  font-size: 13px;
  font-weight: 700;
  line-height: 1;
  opacity: 0.55;
}

.contact-link-arrow {
  display: grid;
  width: 42px;
  height: 42px;
  flex: 0 0 42px;
  place-items: center;
  border-radius: 999px;
  background: #2d63fc;
  color: #f1f8ff;
  font-size: 16px;
  transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
}

.contact-link:hover .contact-link-arrow {
  transform: rotate(45deg);
}

.footer-bottom {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  margin-top: 56px;
  border-top: 1px solid rgba(241, 248, 255, 0.28);
  padding-top: 22px;
  color: rgba(241, 248, 255, 0.74);
  font-size: 13px;
  font-weight: 800;
}

.footer-top-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #f1f8ff;
  transition: opacity 220ms ease;
}

.footer-top-link:hover {
  opacity: 0.72;
}

/* ===== Restyle v3: flat engineering cells (услуги/этапы), work cards, compact footer ===== */

/* --- Services & Steps: flat near-black cells with dashed hairlines and grid texture --- */
.service-bento-panel {
  border: 1px dashed rgba(241, 248, 255, 0.16);
  border-radius: var(--radius-block) !important;
  background: #0a0a0a !important;
  box-shadow: none;
}

/* Сетка + несколько чуть подсвеченных клеток (по мотивам референса) */
.service-bento-panel::after {
  background:
    linear-gradient(rgba(241, 248, 255, 0.05), rgba(241, 248, 255, 0.05)) 136px 34px / 34px 34px no-repeat,
    linear-gradient(rgba(241, 248, 255, 0.035), rgba(241, 248, 255, 0.035)) 34px 102px / 34px 34px no-repeat,
    linear-gradient(rgba(241, 248, 255, 0.045), rgba(241, 248, 255, 0.045)) 306px 0 / 34px 34px no-repeat,
    linear-gradient(rgba(241, 248, 255, 0.03), rgba(241, 248, 255, 0.03)) 238px 68px / 34px 34px no-repeat,
    linear-gradient(90deg, rgba(241, 248, 255, 0.045) 1px, transparent 1px) 0 0 / 34px 34px,
    linear-gradient(0deg, rgba(241, 248, 255, 0.045) 1px, transparent 1px) 0 0 / 34px 34px;
  mask-image: linear-gradient(180deg, #000, transparent 72%);
  opacity: 1;
}

.service-bento-panel-interactive:hover {
  transform: translateY(-3px);
  border-color: rgba(241, 248, 255, 0.34) !important;
  box-shadow: 0 22px 54px rgba(0, 0, 0, 0.32);
}

.service-copy-block {
  display: block;
  min-height: 0;
}

.panel-icon {
  display: block;
  margin-bottom: 26px;
  color: #f1f8ff;
  opacity: 0.92;
}

.panel-icon svg {
  width: 38px;
  height: 38px;
}

.services-section h3 {
  font-size: 24px !important;
  font-weight: 800 !important;
  letter-spacing: -0.01em;
  line-height: 1.15 !important;
}

.services-section .service-copy-block p,
.services-section .service-bento-panel p {
  margin-top: 12px;
  max-width: 46ch;
  color: rgba(241, 248, 255, 0.58) !important;
  font-size: 15px !important;
  font-weight: 450 !important;
  line-height: 1.55 !important;
}

.service-tool-pill {
  border: 1px dashed rgba(241, 248, 255, 0.16);
  background: transparent;
  color: rgba(241, 248, 255, 0.72);
  font-weight: 650;
}

/* Steps cards → same engineering language */
.step-card {
  border: 1px dashed rgba(241, 248, 255, 0.16);
  background: #0a0a0a;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.22);
}

.step-card::before {
  background:
    linear-gradient(90deg, rgba(241, 248, 255, 0.045) 1px, transparent 1px) 0 0 / 34px 34px,
    linear-gradient(0deg, rgba(241, 248, 255, 0.045) 1px, transparent 1px) 0 0 / 34px 34px;
  mask-image: linear-gradient(180deg, #000, transparent 72%);
}

.step-card h3 {
  font-size: clamp(30px, 3.6vw, 50px);
  font-weight: 850;
}

.step-card p {
  color: rgba(241, 248, 255, 0.6) !important;
  font-size: 16px;
  font-weight: 450;
}

.step-card-topline,
.step-card-footer {
  color: rgba(241, 248, 255, 0.48);
}

/* --- Gallery: photo cards with top-left copy and glass CTA --- */
.work-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

@media (min-width: 768px) {
  .work-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

.work-card {
  position: relative;
  overflow: clip;
  aspect-ratio: 4 / 4.4;
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-block);
  background: #0a0a0a;
}

@media (min-width: 1024px) {
  .work-card {
    aspect-ratio: 4 / 4.1;
  }
}

.work-card-img {
  object-fit: cover;
  filter: saturate(0.92);
  transition:
    transform 720ms cubic-bezier(0.16, 1, 0.3, 1),
    filter 480ms ease;
}

.work-card:hover .work-card-img {
  transform: scale(1.028);
  filter: saturate(1);
}

.work-card-shade {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(5, 5, 5, 0.68), rgba(5, 5, 5, 0.22) 32%, transparent 54%, rgba(5, 5, 5, 0.52));
}

.work-card-copy {
  position: absolute;
  left: 26px;
  right: 26px;
  top: 24px;
  color: #f1f8ff;
}

.work-card-copy h3 {
  font-size: clamp(24px, 2.4vw, 34px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.01em;
}

.work-card-copy p {
  margin-top: 10px;
  max-width: 44ch;
  color: rgba(241, 248, 255, 0.76);
  font-size: 14px;
  font-weight: 450;
  line-height: 1.5;
}

.work-card-btn {
  position: absolute;
  left: 18px;
  right: 18px;
  bottom: 18px;
  min-height: 54px;
  border: 1px solid rgba(241, 248, 255, 0.28);
  border-radius: 16px;
  background: rgba(241, 248, 255, 0.12);
  backdrop-filter: blur(16px);
  color: #f1f8ff;
  font-size: 15px;
  font-weight: 750;
  cursor: pointer;
  transition:
    background-color 260ms ease,
    border-color 260ms ease,
    transform 260ms ease;
}

.work-card-btn:hover,
.work-card-btn:focus-visible {
  background: rgba(241, 248, 255, 0.22);
  border-color: rgba(241, 248, 255, 0.4);
  outline: none;
}

/* Modal media stack: several images / videos scroll inside the panel */
.portfolio-modal-media {
  display: grid;
  gap: 10px;
  background: #050505;
}

.portfolio-modal-media video {
  display: block;
  width: 100%;
}

/* --- Footer: compact, dark, quiet --- */
.contact-link {
  min-height: 64px;
  border-radius: 14px;
  padding: 14px 18px;
}

.contact-link-label {
  font-size: 16px;
}

.contact-link-handle {
  margin-top: 6px;
  font-size: 12px;
}

.contact-link-arrow {
  width: 36px;
  height: 36px;
  flex: 0 0 36px;
  font-size: 14px;
}

.footer-bottom {
  margin-top: 34px;
  border-top-color: rgba(241, 248, 255, 0.14);
  padding-top: 16px;
  color: rgba(241, 248, 255, 0.58);
  font-weight: 700;
}

.panel-icon-inline {
  margin-bottom: 20px;
}

/* ===== v4: living hairline, tighter blocks, ghost buttons. ===== */

/* Неявное «дыхание» пунктирной обводки */
@keyframes hairline-breathe {
  0%, 100% { border-color: rgba(241, 248, 255, 0.13); }
  50% { border-color: rgba(241, 248, 255, 0.32); }
}

.service-bento-panel,
.step-card {
  animation: hairline-breathe 5.6s ease-in-out infinite;
}

.service-bento-panel:nth-child(2) {
  animation-delay: 1.4s;
}

.service-bento-panel:nth-child(3) {
  animation-delay: 2.8s;
}

.step-sticky:nth-child(2) .step-card {
  animation-delay: 1.4s;
}

.step-sticky:nth-child(3) .step-card {
  animation-delay: 2.8s;
}

/* Этапы: компактнее, иконка в углу без нижнего зазора */
.step-card {
  min-height: min(44vh, 420px);
}

.step-card .panel-icon {
  margin-bottom: 0;
}

.step-card .panel-icon svg {
  width: 34px;
  height: 34px;
}

/* --- Ghost buttons: единый прозрачный премиальный стиль --- */
.btn-ghost {
  display: inline-flex;
  min-height: 52px;
  align-items: center;
  justify-content: center;
  gap: 10px;
  border: 1px solid rgba(19, 19, 19, 0.22);
  border-radius: 14px;
  background: rgba(19, 19, 19, 0.04);
  backdrop-filter: blur(12px);
  padding: 0 22px;
  color: #131313;
  font-size: 14px;
  font-weight: 800;
  line-height: 1;
  cursor: pointer;
  transition:
    border-color 240ms ease,
    background-color 240ms ease,
    color 240ms ease,
    transform 240ms ease;
}

.btn-ghost:hover {
  border-color: rgba(45, 99, 252, 0.55);
  background: rgba(45, 99, 252, 0.07);
  color: #2d63fc;
}

.btn-ghost:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px #2d63fc;
}

.btn-ghost:active {
  transform: translateY(1px);
}

.btn-ghost .btn-arrow {
  font-size: 15px;
  opacity: 0.68;
  transition: transform 240ms ease, opacity 240ms ease;
}

.btn-ghost:hover .btn-arrow {
  transform: translate(2px, -2px);
  opacity: 1;
}

.btn-ghost-ice {
  border-color: rgba(241, 248, 255, 0.24);
  background: rgba(241, 248, 255, 0.06);
  color: #f1f8ff;
}

.btn-ghost-ice:hover {
  border-color: rgba(241, 248, 255, 0.46);
  background: rgba(241, 248, 255, 0.13);
  color: #f1f8ff;
}

.btn-ghost-ice:focus-visible {
  box-shadow: 0 0 0 2px rgba(241, 248, 255, 0.8);
}

.btn-sm {
  min-height: 40px;
  border-radius: 11px;
  padding: 0 16px;
  font-size: 13px;
}

/* Контактные плитки — прозрачные */
.contact-link {
  border: 1px solid rgba(241, 248, 255, 0.16);
  background: rgba(241, 248, 255, 0.05);
  backdrop-filter: blur(12px);
  color: #f1f8ff;
}

.contact-link:hover,
.contact-link:focus-visible {
  transform: translateY(-2px);
  border-color: rgba(241, 248, 255, 0.36);
  background: rgba(241, 248, 255, 0.11);
  color: #f1f8ff;
  box-shadow: none;
}

.contact-link-arrow {
  border: 1px solid rgba(241, 248, 255, 0.3);
  background: transparent;
  color: #f1f8ff;
}

.contact-link:hover .contact-link-arrow {
  border-color: #2d63fc;
  background: #2d63fc;
  transform: rotate(45deg);
}

/* Кнопка «Закрыть» в модалке — тоже ghost */
.portfolio-modal-close {
  border: 1px solid rgba(241, 248, 255, 0.24);
  background: rgba(241, 248, 255, 0.06);
  color: #f1f8ff;
  backdrop-filter: blur(10px);
  transition: background-color 220ms ease, border-color 220ms ease, color 220ms ease;
}

.portfolio-modal-close:hover,
.portfolio-modal-close:focus-visible {
  border-color: rgba(241, 248, 255, 0.46);
  background: rgba(241, 248, 255, 0.14);
  color: #f1f8ff;
}

/* ===== v5: glass buttons everywhere, white footer, media slider, random cells. ===== */
:root {
  --radius-btn: 14px;
}

/* Единое скругление и стеклянность всех кнопок */
.btn-ghost {
  border-radius: var(--radius-btn);
  border: 1px solid rgba(19, 19, 19, 0.14);
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(18px) saturate(1.5);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.6),
    0 8px 26px rgba(19, 19, 19, 0.07);
}

.btn-ghost:hover {
  border-color: rgba(45, 99, 252, 0.5);
  background: rgba(255, 255, 255, 0.62);
  color: #2d63fc;
}

.btn-ghost-ice {
  border-color: rgba(241, 248, 255, 0.22);
  background: rgba(241, 248, 255, 0.08);
  box-shadow:
    inset 0 1px 0 rgba(241, 248, 255, 0.2),
    0 8px 26px rgba(0, 0, 0, 0.24);
}

.btn-ghost-ice:hover {
  border-color: rgba(241, 248, 255, 0.44);
  background: rgba(241, 248, 255, 0.15);
  color: #f1f8ff;
}

.btn-sm {
  border-radius: var(--radius-btn);
}

.work-card-btn {
  border-radius: var(--radius-btn);
  box-shadow: inset 0 1px 0 rgba(241, 248, 255, 0.22);
}

.portfolio-modal-close {
  border-radius: var(--radius-btn);
}

.portfolio-modal-close-x {
  border-radius: var(--radius-btn);
  background: rgba(10, 10, 10, 0.55);
  backdrop-filter: blur(14px);
}

/* Этапы: ещё компактнее, ритм плотнее */
.step-card {
  min-height: min(38vh, 360px);
}

.step-sticky + .step-sticky {
  margin-top: 24vh;
}

/* Рандомные подсвеченные клетки (рисуются из компонента) */
.step-card-cells {
  position: absolute;
  inset: 0;
  pointer-events: none;
  mask-image: linear-gradient(180deg, #000, transparent 78%);
}

.step-card-cells i {
  position: absolute;
  width: 34px;
  height: 34px;
  background: #f1f8ff;
}

/* Футер на белом: тёмный текст, стеклянные плитки */
.contact-link {
  border: 1px solid rgba(19, 19, 19, 0.14);
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(18px) saturate(1.4);
  border-radius: var(--radius-btn);
  color: #131313;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
}

.contact-link:hover,
.contact-link:focus-visible {
  transform: translateY(-2px);
  border-color: rgba(45, 99, 252, 0.5);
  background: rgba(255, 255, 255, 0.72);
  color: #131313;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7), 0 14px 34px rgba(19, 19, 19, 0.08);
}

.contact-link-arrow {
  border: 1px solid rgba(19, 19, 19, 0.2);
  background: transparent;
  color: #131313;
}

.contact-link:hover .contact-link-arrow {
  border-color: #2d63fc;
  background: #2d63fc;
  color: #f1f8ff;
  transform: rotate(45deg);
}

.footer-grid {
  opacity: 0.5;
  mix-blend-mode: multiply;
}

.footer-bottom {
  border-top-color: rgba(19, 19, 19, 0.12);
  color: rgba(19, 19, 19, 0.58);
}

.footer-top-link {
  color: #131313;
}

.footer-top-link:hover {
  color: #2d63fc;
  opacity: 1;
}

/* Модалка: строго в стилистике сайта + слайдер медиа */
.portfolio-modal-panel {
  width: min(1000px, 100%);
  max-height: 88vh;
  border: 1px dashed rgba(241, 248, 255, 0.18);
  background: #0a0a0a;
}

.portfolio-modal-scroll {
  max-height: 88vh;
}

.modal-slider {
  position: relative;
  height: min(56vh, 540px);
  border-bottom: 1px solid rgba(241, 248, 255, 0.1);
  background:
    linear-gradient(90deg, rgba(241, 248, 255, 0.03) 1px, transparent 1px) 0 0 / 34px 34px,
    linear-gradient(0deg, rgba(241, 248, 255, 0.03) 1px, transparent 1px) 0 0 / 34px 34px,
    #050505;
}

.modal-slide {
  position: absolute;
  inset: 0;
  animation: modal-slide-in 340ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.modal-slide-media {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  animation: modal-slide-in 340ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

@keyframes modal-slide-in {
  from {
    opacity: 0;
    transform: scale(0.985);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-slider-btn {
  position: absolute;
  top: 50%;
  z-index: 2;
  display: grid;
  width: 46px;
  height: 46px;
  place-items: center;
  transform: translateY(-50%);
  border: 1px solid rgba(241, 248, 255, 0.24);
  border-radius: var(--radius-btn);
  background: rgba(10, 10, 10, 0.55);
  backdrop-filter: blur(14px);
  color: #f1f8ff;
  font-size: 24px;
  line-height: 1;
  cursor: pointer;
  transition: background-color 220ms ease, border-color 220ms ease;
}

.modal-slider-btn:hover,
.modal-slider-btn:focus-visible {
  border-color: rgba(241, 248, 255, 0.46);
  background: rgba(241, 248, 255, 0.14);
  outline: none;
}

.modal-slider-prev {
  left: 14px;
}

.modal-slider-next {
  right: 14px;
}

.modal-slider-count {
  position: absolute;
  right: 14px;
  bottom: 14px;
  z-index: 2;
  border: 1px solid rgba(241, 248, 255, 0.2);
  border-radius: 10px;
  background: rgba(10, 10, 10, 0.55);
  backdrop-filter: blur(14px);
  padding: 8px 12px;
  color: rgba(241, 248, 255, 0.85);
  font-size: 12px;
  font-weight: 800;
  line-height: 1;
}

@media (max-width: 640px) {
  .modal-slider {
    height: 46vh;
  }
}

/* ===== v6: readable work-card tops, footer contrast fixes ===== */

/* Верх карточки работы: блюр подложки + затемнение, чтобы заголовок и текст читались */
.work-card-shade {
  background: linear-gradient(180deg, rgba(5, 5, 5, 0.74), rgba(5, 5, 5, 0.28) 34%, transparent 56%, rgba(5, 5, 5, 0.52));
}

.work-card-shade::before {
  position: absolute;
  inset: 0 0 auto 0;
  height: 46%;
  content: "";
  backdrop-filter: blur(14px);
  mask-image: linear-gradient(180deg, #000 26%, transparent 100%);
  background: linear-gradient(180deg, rgba(5, 5, 5, 0.34), transparent 82%);
}

/* Футер: ховер плиток больше не «белое на белом» — тёмная инверсия */
.contact-link:hover,
.contact-link:focus-visible {
  transform: translateY(-2px);
  border-color: #131313;
  background: #131313;
  color: #f1f8ff;
  box-shadow: 0 16px 38px rgba(19, 19, 19, 0.18);
}

.contact-link:hover .contact-link-handle,
.contact-link:focus-visible .contact-link-handle {
  opacity: 0.66;
}

.contact-link:hover .contact-link-arrow,
.contact-link:focus-visible .contact-link-arrow {
  border-color: #2d63fc;
  background: #2d63fc;
  color: #f1f8ff;
  transform: rotate(45deg);
}

/* Мерцающая сетка в футере — заметнее на светлом */
.footer-grid {
  opacity: 0.85;
  mix-blend-mode: multiply;
}
